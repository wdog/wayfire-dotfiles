{
  "search_paths": [
    "~/.config",
    "~/.cache"
  ],
  "file_patterns": [
    "*.ini",
    "*.conf",
    "*.cfg",
    "*.toml",
    "*.yaml",
    "*.yml",
    "*.json",
    ".*rc",
    ".*profile",
    ".*_history"
  ],
  "gitignore_patterns": [
    "*.log",
    "*.tmp",
    "*.cache",
    "*.lock",
    "**/cache/**",
    "**/Cache/**",
    "**/logs/**",
    "**/tmp/**",
    "**/.git/**",
    "**/node_modules/**",
    "**/__pycache__/**",
    "*.pyc",
    "*.pyo",
    "**/Session.vim",
    "**/sessions/**",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/*.swp",
    "**/*.swo",
    "**/*~",
    "**/recently-used.xbel",
    "**/user-dirs.dirs",
    "**/user-dirs.locale",
    "**/mimeapps.list",
    "**/QtProject.conf",
    "**/unity3d/**",
    "**/pulse/cookie",
    "**/dconf/user",
    "**/chromium/Default/History*",
    "**/chromium/Default/Cookies*",
    "**/chromium/Default/Sessions/**",
    "**/firefox/*/sessionstore*",
    "**/firefox/*/places.sqlite*",
    "**/firefox/*/cookies.sqlite*"
  ],
  "exclude_dirs": [
    ".git",
    "node_modules",
    "__pycache__",
    ".cache",
    "cache",
    "Cache",
    "logs",
    "tmp",
    "temp",
    "sessions",
    "Session Data",
    "GPUCache",
    "ShaderCache",
    "CachedData"
  ],
  "max_file_size_mb": 1,
  "auto_add_to_gitignore": true,
  "backup_before_restore": true,
  "default_commit_template": "Update dotfiles - {timestamp}",
  "show_hidden_files": true,
  "sort_files_by": "name",
  "color_scheme": {
    "header": "blue",
    "selected": "white_on_blue",
    "success": "green",
    "error": "red",
    "warning": "yellow",
    "info": "cyan",
    "special": "magenta"
  },
  "keybindings": {
    "select_all": [
      "a",
      "A"
    ],
    "select_none": [
      "n",
      "N"
    ],
    "quit": [
      "q",
      "Q"
    ],
    "help": [
      "h",
      "H",
      "?"
    ]
  }
}